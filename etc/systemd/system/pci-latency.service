[Unit]
Description=Optimize PCI Latency Timers for Responsiveness
Documentation=https://wiki.archlinux.org/title/PCI_latency
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/pci-latency
StandardOutput=journal
StandardError=journal

# Continue boot even if script fails
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
